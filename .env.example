# ──────────────────────────────────────────────────────────────────────────────
# Atlas Logging — Environment Variables
# Copy this file to .env and fill in the values before running the bot locally.
# On Railway, set these as service variables in the dashboard.
# ──────────────────────────────────────────────────────────────────────────────

# Your Discord bot token (from https://discord.com/developers/applications)
DISCORD_TOKEN=your-bot-token-here

# The ID of the text channel where all log messages will be sent.
# Right-click a channel in Discord → "Copy Channel ID" (Developer Mode must be on).
# If left empty the bot will print logs to stdout instead.
LOG_CHANNEL_ID=your-log-channel-id-here
